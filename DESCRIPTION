Package: treeInvQC
Title: Quality control for tree inventory data in plots
Version: 0.1
Authors@R: 
	c(
		person("John L.", "Godlee", , "johngodlee@gmail.com", role = c("aut", "cre")),
		person("Vincyane", "Badouard", , "vincyane.badouard@gmail.com", role = c("aut"))
